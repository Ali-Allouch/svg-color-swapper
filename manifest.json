{
  "manifest_version": 3,
  "name": "SVG Color Swapper",
  "version": "1.0.1",
  "description": "Easily detect, change, and export SVG colors from any webpage.",
  "icons": {
    "16": "favicon/favicon-16x16.png",
    "32": "favicon/favicon-32x32.png",
    "192": "favicon/android-chrome-192x192.png",
    "512": "favicon/android-chrome-512x512.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "favicon/favicon-16x16.png",
      "32": "favicon/favicon-32x32.png"
    }
  },
  "permissions": [
    "activeTab",
    "scripting"
  ]
}